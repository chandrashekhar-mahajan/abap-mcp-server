# SAP System Connection
SAP_BASE_URL=https://vhcala4hci:44300
SAP_CLIENT=001
SAP_LANGUAGE=en

# Set to true to skip SSL certificate verification (for self-signed certs)
SAP_SKIP_SSL=true

# ─── Authentication Method ──────────────────────────────────────────────
# Options: auto | basic | oauth | kerberos | certificate | browser_sso
#   auto        = uses basic if credentials set, otherwise tries cert, oauth, then browser SSO
#   basic       = username/password (for dev/sandbox or technical users)
#   oauth       = OAuth 2.0 Authorization Code + PKCE (for SSO-enabled systems)
#   kerberos    = Kerberos/SPNEGO via Windows SSPI (for corporate SSO + SAP Secure Login Client)
#   certificate = X.509 client certificate (mutual TLS)
#   browser_sso = Browser-based SSO with cookie capture (for SAML/Kerberos)
AUTH_METHOD=auto

# ─── Basic Auth (when AUTH_METHOD=basic or auto) ────────────────────────
SAP_USERNAME=developer
SAP_PASSWORD=

# ─── OAuth 2.0 (when AUTH_METHOD=oauth) ────────────────────────────────
# Configure OAuth client in SAP transaction SOAUTH2
# Redirect URI must be: http://localhost:3001/auth/callback
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPE=SAP_ADT

# ─── Kerberos/SPNEGO (when AUTH_METHOD=kerberos) ───────────────────────
# Both are auto-detected from SAP_BASE_URL hostname — only set to override
# KERBEROS_REALM=CORP.EXAMPLE.COM
# KERBEROS_SPN=HTTP/sapserver.corp.example.com@CORP.EXAMPLE.COM

# ─── X.509 Certificate (when AUTH_METHOD=certificate) ──────────────────
CLIENT_CERT_PATH=
CLIENT_KEY_PATH=
CA_CERT_PATH=
CLIENT_KEY_PASSPHRASE=

# ─── Server Configuration ──────────────────────────────────────────────
# stdio = Eclipse ADT runs this as a local process
# sse   = runs as HTTP server, Eclipse ADT connects via URL
SERVER_MODE=sse
SSE_PORT=3001
